{
  "name": "veritio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:motia": "bun run --bun motia-iii dev",
    "dev:next": "bun run --bun next dev -p 4001",
    "dev:yjs": "bun --env-file=../../.env.local run --watch scripts/yjs-server/server.ts",
    "dev:hmr": "concurrently --kill-others \"bun run dev:motia\" \"bun run dev:next --turbo\" \"bun run dev:yjs\"",
    "build": "bun run --bun next build",
    "build:analyze": "ANALYZE=true bun run --bun next build",
    "analyze": "ANALYZE=true bun run --bun next build",
    "analyze:server": "BUNDLE_ANALYZE=server bun run --bun next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser bun run --bun next build",
    "build:widget": "bun run scripts/minify-widget.ts",
    "build-rrweb-embed": "bun run scripts/build-rrweb-embed.ts",
    "build-rrweb-record-embed": "bun run scripts/build-rrweb-record-embed.ts",
    "start": "bun run --bun next start",
    "lint": "eslint .",
    "test": "bun test",
    "test:vitest": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "bun e2e/index.ts",
    "test:e2e:headed": "AGENT_BROWSER_HEADED=1 bun e2e/index.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .motia/compiled dist node_modules/.cache",
    "dev:profile": "node --inspect ../../node_modules/.bin/motia-iii",
    "dev:profile:break": "node --inspect-brk ../../node_modules/.bin/motia-iii"
  },
