{
  "name": "veritio-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/@veritio/*",
    "packages/config/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=veritio",
    "dev:all": "turbo run dev --filter=veritio",
    "dev:veritio": "turbo run dev --filter=veritio",
    "build": "echo 'Skipping build for Railway backend deployment'",
    "build:full": "turbo run build",
    "build:veritio": "turbo run build --filter=veritio",
    "start": "cd apps/veritio && npx motia-iii",
    "start:backend": "cd apps/veritio && npx motia-iii",
    "start:yjs": "cd apps/veritio && node scripts/yjs-server/server.ts",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:vitest": "turbo run test:vitest",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:build": "rm -rf apps/*/.next apps/*/dist dist reports *.tsbuildinfo packages/**/*.tsbuildinfo",
    "clean:all": "bun run clean:build && bun run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "clinic": "^13.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.5.4"
  },
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "date-fns": "^4.1.0",
    "react-day-picker": "^9.4.1"
  }
}
