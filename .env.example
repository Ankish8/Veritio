# ===========================================
# SUPABASE CONFIGURATION
# ===========================================

# Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key (SECRET - server only)
# This bypasses RLS - never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ===========================================
# DATABASE
# ===========================================

# PostgreSQL connection via Supabase pooler
# Format: postgresql://postgres.[PROJECT]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://...

# ===========================================
# AUTHENTICATION (Better Auth)
# ===========================================

# Secret key for Better Auth session signing (32+ chars)
BETTER_AUTH_SECRET=your-better-auth-secret

# ===========================================
# APPLICATION
# ===========================================

# Frontend runs on port 4001, Motia backend on port 4000
NEXT_PUBLIC_APP_URL=http://localhost:4001

# Redis URL for queue, state, and stream modules
REDIS_URL=redis://localhost:6379

# ===========================================
# ADMIN PANEL
# ===========================================

# User ID of the superadmin who can access /admin panel
# Set this to YOUR user ID after creating your account
# Find your user ID in the `user` table in Supabase
SUPERADMIN_USER_ID=
# NEXT_PUBLIC_SUPERADMIN_USER_ID is no longer used — admin checks are server-side via SUPERADMIN_USER_ID only

# ===========================================
# POOL CONFIGURATION (Optional)
# ===========================================

# Override default pool settings if needed
# DB_POOL_MIN=5
# DB_POOL_MAX=25

# ===========================================
# PDF EXPORT
# ===========================================

# Secret key for signing PDF render tokens (32+ chars recommended)
PDF_RENDER_SECRET=your-pdf-render-secret-key

# ===========================================
# AI ASSISTANT (Optional - powers "Build with AI", chat, insights)
# ===========================================

# OpenAI API key — used for chat assistant, AI card sort/tree test builder, insights reports
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key

# Mercury API key — used for text refinement, title generation, knowledge Q&A
# Get from: https://mercury.ai
# INCEPTION_API_KEY=your-mercury-api-key

# Override default model names (optional)
# OPENAI_MODEL=gpt-5-mini
# ASSISTANT_MODEL=mercury-2

# ===========================================
# FIGMA INTEGRATION (Optional - for Prototype Testing)
# ===========================================

# Figma OAuth and Embed API
# Get from: https://www.figma.com/developers/apps
FIGMA_CLIENT_ID=your-figma-oauth-client-id
FIGMA_CLIENT_SECRET=your-figma-oauth-client-secret
FIGMA_REDIRECT_URI=http://localhost:4001/api/integrations/figma/callback
NEXT_PUBLIC_FIGMA_EMBED_CLIENT_ID=your-figma-oauth-client-id

# ===========================================
# CLOUDFLARE R2 (Optional - for Session Recording Storage)
# ===========================================

# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_DOMAIN=your-r2-public-domain

# ===========================================
# DEEPGRAM (Optional - for Audio Transcription and Voice)
# ===========================================

# Get from: https://console.deepgram.com/
# DEEPGRAM_API_KEY=your-deepgram-api-key


# ===========================================
# EMAIL NOTIFICATIONS (Optional)
# ===========================================

# Resend API key for sending email notifications (study completion, invitations)
# Get from: https://resend.com/api-keys
# RESEND_API_KEY=your-resend-api-key

# ===========================================
# TRANSLATION (Optional)
# ===========================================

# DeepL API key for translating study content
# Get from: https://www.deepl.com/pro-api
# DEEPL_API_KEY=your-deepl-api-key

# ===========================================
# GOOGLE OAUTH (Optional - for Google sign-in)
# ===========================================

# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# COMPOSIO (Optional - for third-party integrations)
# ===========================================

# Composio API key for Google Sheets, Slack, and other integrations
# Get from: https://composio.dev
# COMPOSIO_API_KEY=your-composio-api-key
# COMPOSIO_WEBHOOK_SECRET=your-composio-webhook-secret

# ===========================================
# REAL-TIME COLLABORATION (Optional)
# ===========================================

# Master switch - set to "true" to enable real-time features
NEXT_PUBLIC_REALTIME_V2_ENABLED=false

# Rollout percentage (0-100)
NEXT_PUBLIC_REALTIME_V2_PERCENTAGE=0

# WebSocket server URL
# Local development: ws://localhost:4002
# Production: wss://your-realtime-server.railway.app
NEXT_PUBLIC_REALTIME_SERVER_URL=ws://localhost:4002

# Internal API key for Yjs server authentication (generate a random string)
# YJS_INTERNAL_API_KEY=your-random-secret

# ===========================================
# DEVELOPMENT
# ===========================================

# Comma-separated list of allowed dev origins for Next.js (Tailscale, ngrok, etc.)
# ALLOWED_DEV_ORIGINS=my-machine.tailnet.ts.net

# ===========================================
# LIVE WEBSITE TESTING (Optional)
# ===========================================

# Proxy worker URL for reverse-proxy mode
# Deploy the worker from /workers directory to Cloudflare
# NEXT_PUBLIC_PROXY_WORKER_URL=https://your-proxy-worker.workers.dev

# ===========================================
# MOTIA STREAMS (Optional)
# ===========================================

# Stream WebSocket URL (default: ws://localhost:4004)
# NEXT_PUBLIC_MOTIA_WS_URL=ws://localhost:4004

# ===========================================
# SEED SCRIPTS (Optional - for populating dev data)
# ===========================================

# Your Better Auth user ID — find it in the `user` table after creating your account
# Required when running scripts in apps/veritio/scripts/seed/
# SEED_USER_ID=your-better-auth-user-id

# Existing project ID to seed studies into (optional — generates a new one if not set)
# SEED_PROJECT_ID=your-project-uuid

# Organization ID for seeds that need org context (optional)
# SEED_ORGANIZATION_ID=your-organization-uuid

# ===========================================
# E2E TESTING (Optional - for running Playwright tests)
# ===========================================

# Test user credentials for E2E tests
# Create a dedicated test account in your dev environment
# E2E_TEST_EMAIL=test@example.com
# E2E_TEST_PASSWORD=test-password
